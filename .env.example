# Neon Postgres connection string — opprett gratis prosjekt på https://neon.tech
DATABASE_URL=

# Auth.js-hemmelighet — generer med: npx auth secret
AUTH_SECRET=

# Resend API-nøkkel for e-postvarsling — https://resend.com
RESEND_API_KEY=

# Avsenderadresse for e-postvarsler (må være verifisert domene i Resend)
EMAIL_FROM=

# Basis-URL for appen — brukes i e-postlenker (avbestilling osv.)
NEXT_PUBLIC_APP_URL=http://localhost:3000
