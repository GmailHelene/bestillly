# Neon Postgres connection string — opprett gratis prosjekt på https://neon.tech
DATABASE_URL=

# Auth.js-hemmelighet — generer med: npx auth secret
AUTH_SECRET=

# Brevo SMTP for e-postvarsling — https://brevo.com
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Avsenderadresse for e-postvarsler (må være verifisert avsender i Brevo)
EMAIL_FROM=

# Basis-URL for appen — brukes i e-postlenker (avbestilling osv.)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Cloudinary — bildeopplasting
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=

# E-postadressen til bestilly-operatøren — gir tilgang til /drift
OPERATOR_EMAIL=
